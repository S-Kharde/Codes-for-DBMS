SELECT MAX(salary) 
FROM emp
WHERE job = 'Salesman';
SELECT * FROM emp
WHERE ename LIKE 'I%';
SELECT * FROM emp
ORDER BY salary DESC;
SELECT hiredate,
AVG(salary) AS avg_salary,
MIN(salary) AS min_salary
FROM emp
WHERE deptno = 10
GROUP BY hiredate;
SELECT e.ename, d.deptname
FROM emp e, dept d
WHERE e.deptno = d.deptno;
SELECT d.deptname, SUM(e.salary) AS total_salary
FROM emp e, dept d
WHERE e.deptno = d.deptno
GROUP BY e.deptno;
SELECT e.ename
FROM emp e, dept d
WHERE e.deptno = d.deptno
AND d.deptname = 'Dev';
